{
  "name": "n8n-nodes-revenuecat",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for RevenueCat providing 11 resources and 40+ operations for in-app subscription management. Includes subscriber management, entitlements, products, offerings, packages, purchases, analytics, and webhook triggers.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-revenuecat.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-revenuecat",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-revenuecat/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "revenuecat",
    "subscriptions",
    "in-app-purchases",
    "mobile",
    "ios",
    "android",
    "payments",
    "revenue",
    "monetization"
  ],
  "main": "dist/nodes/RevenueCat/RevenueCat.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RevenueCatApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RevenueCat/RevenueCat.node.js",
      "dist/nodes/RevenueCat/RevenueCatTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}